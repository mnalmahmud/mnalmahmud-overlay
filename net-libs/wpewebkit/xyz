// Toggle system allocator instead of WebKit's custom allocator
USE_SYSTEM_MALLOC:BOOL=OFF

// Whether to use a system-provided libsysprof-capture
USE_SYSTEM_SYSPROF_CAPTURE:BOOL=ON

// Whether to use a system-provided unifdef
USE_SYSTEM_UNIFDEF:BOOL=ON

// Produce all static libraries as thin archives
